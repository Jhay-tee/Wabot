# WaBot Frontend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# In development: leave VITE_API_BASE_URL empty — Vite proxies /api → localhost:3000
# In production:  set VITE_API_BASE_URL to your Render backend URL
# ─────────────────────────────────────────────────────────────────────────────

# Your backend API base URL — include /api at the end.
# Dev:  leave empty (Vite proxy handles it)
# Prod: https://your-wabot-api.onrender.com/api
VITE_API_BASE_URL=
