{
  "name": "wabot",
  "version": "1.0.0",
  "description": "WhatsApp Bot using Baileys + Supabase + Express",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "nodemon index.js",
    "clear-session": "node -e \"import('./db.js').then(m => m.clearSession())\"",
    "lint": "eslint . --ext .js",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@hapi/boom": "^10.0.1",
    "@supabase/supabase-js": "^2.45.4",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "dotenv": "^16.4.5",                
    "express": "^4.19.2",
    "pino": "^9.2.0",
    "pino-pretty": "^11.0.0",
    "qrcode": "^1.5.4",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0",
    "eslint": "^9.9.0",
    "prettier": "^3.3.3"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "volta": {
    "node": "20.17.0"
