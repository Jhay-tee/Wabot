# WaBot Backend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in all values.
# In production (Render), set these as Environment Variables in the Render dashboard.
#
# PRODUCTION ARCHITECTURE:
#   Frontend: Vercel or Netlify (static site, free)
#   Backend:  Render (Express API, free tier or $7/month always-on)
#   Database: Supabase (free tier)
#
# DEV ARCHITECTURE:
#   Frontend: Vite on port 5000 (proxies /api → localhost:3000)
#   Backend:  Express on port 3000
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── App URLs ──────────────────────────────────────────────────────────────────
# APP_BASE_URL: Your frontend URL — used in verification emails and Paystack redirects.
#   Dev:  http://localhost:5000
#   Prod: https://your-wabot.vercel.app  (or your custom domain)
APP_BASE_URL=http://localhost:5000

# API_BASE_URL: Your backend URL — used in dev logging.
#   Dev:  http://localhost:3000
#   Prod: https://your-wabot-api.onrender.com
API_BASE_URL=http://localhost:3000

# ALLOWED_ORIGINS: Comma-separated list of frontend URLs allowed to call the API.
#   Dev:  http://localhost:5000
#   Prod: add your Vercel/Netlify URL here, e.g:
#         https://your-wabot.vercel.app,https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5000

# ── Auth (REQUIRED) ───────────────────────────────────────────────────────────
# Strong random secret for JWT signing — minimum 32 characters.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this

# ── Supabase (REQUIRED) ───────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
# Use the SERVICE ROLE key (not the anon key).
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJh...your-service-role-key

# ── Brevo / Email (optional in dev, required in prod) ─────────────────────────
# Sign up free at https://app.brevo.com
# In dev without these: verification link is printed to the server console instead.
# In prod without these: users cannot verify their email and bots cannot deploy.
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=hello@yourdomain.com
BREVO_SENDER_NAME=WaBot

# ── Paystack / Billing (optional) ─────────────────────────────────────────────
# Only needed when enabling paid Pro plans.
# Without these: the billing tab shows "not configured" but everything else works.
#
# 1. Create a monthly plan in Paystack for ₦1,500/month
# 2. Set PAYSTACK_PLAN_CODE to the plan code (starts with PLN_)
# 3. Add a webhook in Paystack Dashboard:
#    URL:    https://your-wabot-api.onrender.com/api/billing/webhook
#    Events: charge.success, subscription.disable, subscription.not_renew
PAYSTACK_SECRET_KEY=sk_test_xxx
PAYSTACK_WEBHOOK_SECRET=your-paystack-webhook-secret
PAYSTACK_PLAN_CODE=PLN_xxxxxxxxxx

# ── Admin Panel (optional) ────────────────────────────────────────────────────
# Set this to YOUR account email to unlock the /admin route.
# Anyone with a different email cannot access it at all.
SUPERADMIN_EMAIL=you@yourdomain.com
