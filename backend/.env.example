# WaBot Backend — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in all values.
# In production (Replit Deploy), set these as Secrets in the deployment dashboard.
#
# PRODUCTION ARCHITECTURE:
#   The backend (Express) serves BOTH the compiled frontend AND the /api routes
#   on a single port (5000). The frontend uses relative /api paths — no CORS
#   needed in production. All traffic flows through one process on one domain.
#
# DEV ARCHITECTURE:
#   Frontend: Vite on port 5000 (proxies /api → localhost:3000)
#   Backend:  Express on port 3000
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── App URLs ──────────────────────────────────────────────────────────────────
# APP_BASE_URL: Used in verification emails and Stripe redirect URLs.
#   Dev:  http://localhost:5000
#   Prod: https://yourapp.replit.app  (or your custom domain)
APP_BASE_URL=http://localhost:5000

# API_BASE_URL: Internal URL of the backend (used in dev logging only).
#   Dev:  http://localhost:3000
#   Prod: not needed (same process as frontend)
API_BASE_URL=http://localhost:3000

# ALLOWED_ORIGINS: Comma-separated CORS origins (dev only — not used in prod).
#   In dev, this should include your Replit preview domain and localhost.
ALLOWED_ORIGINS=http://localhost:5000

# ── Auth (REQUIRED) ───────────────────────────────────────────────────────────
# Strong random secret for JWT signing — minimum 32 characters.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-change-this

# ── Supabase (REQUIRED) ───────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
# Use the SERVICE ROLE key (not the anon key) — our Express backend uses it
# to bypass Row Level Security for all DB operations.
SUPABASE_URL=https://xxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJh...your-service-role-key

# ── Brevo / Email (optional in dev, recommended in prod) ─────────────────────
# Email verification is sent via Brevo (https://app.brevo.com).
# In dev without these set: the verification URL is logged to the console.
# In prod without these set: users cannot verify their email (bots can't deploy).
BREVO_API_KEY=xkeysib-...
BREVO_SENDER_EMAIL=hello@yourdomain.com
BREVO_SENDER_NAME=WaBot

# ── Stripe / Billing (optional) ───────────────────────────────────────────────
# Only needed when enabling paid Pro plans.
# Without these set: the /api/billing/* endpoints return 503.
#
# 1. Create a product in Stripe Dashboard with a recurring price
# 2. Set STRIPE_PRICE_ID_GROWTH to the price ID (price_xxx)
# 3. Configure the webhook endpoint in Stripe → Webhooks:
#    URL: https://yourapp.replit.app/api/billing/webhook
#    Events: checkout.session.completed, customer.subscription.deleted,
#            customer.subscription.updated
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID_GROWTH=price_...
